# Flask configuration
SECRET_KEY=your_super_secret_production_key_here
FLASK_ENV=production

# Database configuration (Replace with your actual production DB details)
# E.g., for AWS RDS, DigitalOcean Managed DB, or Railway:
DATABASE_URL=mysql+pymysql://username:password@host:port/database_name

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Microsoft Entra ID (Azure AD) OAuth 2.0
# Register your app at https://portal.azure.com → Azure Active Directory → App Registrations
# Add Redirect URI: https://yourdomain.com/auth/microsoft/callback
MICROSOFT_CLIENT_ID=your_microsoft_application_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_value_here
