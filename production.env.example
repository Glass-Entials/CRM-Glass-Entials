# ─────────────────────────────────────────────────────────────────────────────
# production.env.example
# Copy this to .env on each deployment environment.
# NEVER commit actual .env values to git.
# In production: use AWS Secrets Manager and inject via ECS task definition
# or EC2 instance profile + startup script.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask core ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# development | production | testing
FLASK_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Local:      mysql+pymysql://user:password@localhost/crm_db
# RDS (prod): mysql+pymysql://user:password@rds-endpoint.rds.amazonaws.com/crm_db?ssl_ca=/etc/ssl/rds-ca.pem
DATABASE_URL=mysql+pymysql://crm_user:STRONG_PASSWORD@YOUR_RDS_ENDPOINT/crm_db

# ── Session & Cookie hardening ────────────────────────────────────────────────
# Always true behind ALB/HTTPS
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
# Session lifetime in seconds (8 hours)
PERMANENT_SESSION_LIFETIME=28800

# ── File uploads ──────────────────────────────────────────────────────────────
# Max upload size in bytes (default 5MB)
MAX_CONTENT_LENGTH=5242880
# Absolute path to local upload folder (overridden by S3 in production)
UPLOAD_FOLDER=/var/www/crm/static/uploads

# ── GST API Integration ───────────────────────────────────────────────────────
# ROTATE THESE — previous values were committed to git
GST_CLIENT_ID=REPLACE_WITH_NEW_CLIENT_ID
GST_CLIENT_SECRET=REPLACE_WITH_NEW_CLIENT_SECRET

# ── AWS (Production only) ─────────────────────────────────────────────────────
# AWS Region for Secrets Manager + S3
AWS_REGION=ap-south-1

# Set to "true" to load secrets from AWS Secrets Manager instead of .env
USE_AWS_SECRETS=false
# Secret name in AWS Secrets Manager (if USE_AWS_SECRETS=true)
AWS_SECRET_NAME=crm-glassentials/prod

# S3 bucket for document storage (leave blank to use local filesystem)
S3_BUCKET_NAME=
S3_UPLOAD_PREFIX=crm-docs/

# ── Redis (for Flask-Limiter + future caching) ────────────────────────────────
# Local:      redis://localhost:6379/0
# AWS ElastiCache: redis://your-elasticache-endpoint:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=WARNING
